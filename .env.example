# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Owner role. Runs migrations + seeds, and backs the "system" Prisma client used
# for cross-tenant control-plane reads (login, domain resolution). Bypasses RLS.
DATABASE_URL="postgresql://zcms:zcms@localhost:5432/zcms?schema=public"

# Runtime role. Every tenant-scoped query goes through this connection, which is
# subject to Row-Level Security. NEVER point this at the owner role.
APP_DATABASE_URL="postgresql://zcms_app:zcms_app@localhost:5432/zcms?schema=public"

# Postgres connections per pool, per process. Two pools exist (system + RLS app),
# and cms-api and the worker each hold their own — so the real ceiling on the
# server is roughly this times four. Raise it only alongside Postgres's own
# max_connections.
DB_POOL_MAX="10"

# ---------------------------------------------------------------------------
# First admin, created by `pnpm db:seed`.
#
# Leave the password unset and the seed uses "admin123" — which is fine on a
# laptop and is exactly the credential an internet-facing instance gets owned
# through. Set it before you seed anything you intend to expose.
#
# On re-seed the password is only rewritten when SEED_ADMIN_PASSWORD is set, so a
# rotated password is not silently reverted by a later seed run.
#
# With NODE_ENV=production the seed now REFUSES to run with this empty or set to a
# well-known value (admin123, password, …) — set a strong secret, or set
# SEED_ON_DEPLOY=0 to skip seeding.
# ---------------------------------------------------------------------------
SEED_ADMIN_EMAIL="admin@z-cms.org"
SEED_ADMIN_PASSWORD=""

# ---------------------------------------------------------------------------
# Redis (cache, locks, rate limit, BullMQ)
#
# For local `pnpm dev` a password-less Redis is fine, so REDIS_URL below has none.
# For any DEPLOYMENT, set REDIS_PASSWORD: the compose/stack files start Redis with
# --requirepass and build an authenticated REDIS_URL from it. site-runtime shares
# the Redis network but is NOT given this password, so a hostile theme cannot read
# or poison the render cache.
# ---------------------------------------------------------------------------
REDIS_PASSWORD=""
REDIS_URL="redis://localhost:6379"

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
JWT_SECRET="dev-only-change-me-in-production"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ---------------------------------------------------------------------------
# Two-factor authentication (TOTP)
#
# A TOTP secret cannot be hashed — the server has to recompute the code on every
# login — so the database necessarily holds something that IS the second factor.
# Left in the clear, one leaked dump hands an attacker every second factor on the
# instance, which is precisely the compromise 2FA exists to survive. This key is
# what makes a dump insufficient on its own: the secrets are stored AES-256-GCM
# encrypted under it, and it lives in the environment, not the database.
#
# 32 random bytes, as base64 or hex:
#
#     node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# Set it ONCE and keep it. Rotating it does not "re-key" anything — it makes every
# enrolled authenticator undecryptable, and every user who has 2FA on has to
# enroll again from scratch. Back it up wherever you back up JWT_SECRET.
# ---------------------------------------------------------------------------
TOTP_ENCRYPTION_KEY="emNtcy1kZXYtdG90cC1rZXktZG8tbm90LXVzZS1pbi0="

# The name an authenticator app shows next to the code. Worth setting when you run
# more than one instance — "Z-CMS" three times in a list is three of nothing.
MFA_ISSUER="Z-CMS"

# ---------------------------------------------------------------------------
# Services
# ---------------------------------------------------------------------------
CMS_API_PORT="4100"
CMS_API_URL="http://localhost:4100"
ADMIN_WEB_URL="http://localhost:3101"
SITE_RUNTIME_URL="http://localhost:3100"

# Primary public hostname of the main site. The deploy-time locale enable step
# uses this to find the site unless you run the script manually with --host/--slug.
ROOT_DOMAIN="localhost:3100"

# Optional deploy-time site locale enablement.
#
# Leave disabled for generic multi-site deployments. For the main public Z-CMS
# site, set ENABLE_SITE_LOCALES_ON_DEPLOY=1 and SITE_LOCALES="en,vi,ja" so the
# migrate job updates Site.locales after each deploy. The script is idempotent.
ENABLE_SITE_LOCALES_ON_DEPLOY="0"
SITE_LOCALES="en,vi,ja"

# Optional. The API's origin as a BROWSER would reach it — set it only if the
# browser genuinely calls the API cross-origin.
#
# CMS_API_URL above is how the front ends reach the API server-side, and in a
# container deployment that is an internal address ("http://z-cms_cms-api:4100").
# The admin and the site name the API in their Content-Security-Policy
# connect-src, and an internal name is useless there — the underscore is not even
# a legal CSP host-source — so anything that is not a public hostname is dropped
# from the CSP rather than emitted. That is the right default: both front ends
# call the API through their own same-origin route handlers, which 'self' already
# covers, so connect-src needs no API origin at all.
#
# Set this only when something in the browser talks to the API directly. Empty =
# fall back to CMS_API_URL (and, if that is internal, to no API origin in the CSP).
CMS_API_PUBLIC_URL=""

# The version string on the OpenAPI document at /api/v1/docs. Cosmetic — it does
# not gate anything.
CMS_API_VERSION="0.1.0"

# Shared secret for service-to-service calls. This is the PRIVILEGED token: the
# worker uses it for side-effecting internal endpoints (mail delivery, job
# dispatch). Keep it out of any process that runs untrusted code.
CMS_INTERNAL_TOKEN="dev-internal-token-change-me"

# The RENDER-channel token, for the cms-api <-> site-runtime path only. site-runtime
# runs third-party theme code in-process, so it is given THIS token, not the
# privileged one; cms-api accepts it only on read-only render endpoints
# (/render/resolve, /ai/chat, bundle download), never /mail/deliver. Set it to a
# value DISTINCT from CMS_INTERNAL_TOKEN in production to get the isolation. Leave
# empty and it falls back to CMS_INTERNAL_TOKEN (no isolation, but nothing breaks).
SITE_RUNTIME_INTERNAL_TOKEN=""

# ---------------------------------------------------------------------------
# Object storage (RustFS in dev, any S3-compatible service in prod)
#
# RustFS speaks the S3 API, so these are plain S3 settings — the same values
# point at AWS S3, Cloudflare R2 or any other provider in production. The dev
# console is at http://localhost:9001.
# ---------------------------------------------------------------------------
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="zcms-media"
S3_ACCESS_KEY="zcms"
S3_SECRET_KEY="zcms-secret"
# Where a BROWSER fetches an uploaded file from — unrelated to S3_ENDPOINT, which is
# how the services reach the bucket. It is whatever your provider serves media on: a
# CDN hostname, an R2 custom domain, or (in dev) RustFS on its own port.
#
# It also becomes the img-src of the admin's and the site's Content-Security-Policy,
# so a wrong value does not fail loudly: the upload succeeds and the browser then
# blocks the image. Both front ends need this var, not just the API.
S3_PUBLIC_URL="http://localhost:9000/zcms-media"

# ---------------------------------------------------------------------------
# Mail (Mailpit in dev: http://localhost:8025)
#
# These are the FALLBACK. A site with a saved configuration (Settings → Mail)
# sends through that instead, and the screen says so. What they are for is the
# case below: a fresh checkout, where Mailpit captures every outgoing email so
# that "does the invite mail work?" can be answered without owning a mail server.
#
# In production, prefer Settings → Mail: the password is encrypted at rest there,
# each site can send as itself, and changing it does not need a restart.
# ---------------------------------------------------------------------------
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="Z-CMS <no-reply@z-cms.org>"
# Mailpit needs neither, and a server that does gets them from Settings → Mail.
SMTP_USER=""
SMTP_PASSWORD=""
# Implicit TLS (SMTPS, port 465). Leave false for 587/STARTTLS — and for Mailpit.
SMTP_SECURE="false"

# ---------------------------------------------------------------------------
# Encrypts the SMTP password stored in Settings → Mail. 32 bytes, base64 or hex:
#
#     node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# Separate from TOTP_ENCRYPTION_KEY on purpose — one key, one job, so that
# rotating the mail credential's key never touches anyone's second factor. An
# instance that never configures mail can leave this unset; it is read on the
# first save, not at boot.
# ---------------------------------------------------------------------------
MAIL_ENCRYPTION_KEY="emNtcy1kZXYtbWFpbC1rZXktZG8tbm90LXVzZS1pbi0="

# How many emails a site's PLUGINS may send per hour, in total. The CMS's own mail
# (invitations, password resets) is not counted against it. This is the cap on how
# bad a compromised or buggy plugin can be for your domain's reputation.
MAIL_PLUGIN_HOURLY_LIMIT="200"

# ---------------------------------------------------------------------------
# Plugin runtime (separate process — holds NO database or storage credentials)
# ---------------------------------------------------------------------------
PLUGIN_RUNTIME_PORT="4200"
PLUGIN_RUNTIME_URL="http://localhost:4200"

# Where the plugin-runtime looks for installed plugins. Defaults to the repo's
# ./plugins, which is what a checkout wants. In a container this must point at the
# same volume cms-api installs into — the two processes disagree about what is
# installed otherwise.
PLUGIN_DIR="./plugins"

# ---------------------------------------------------------------------------
# Marketplace public key (the pinned trust anchor).
#
# This instance is a marketplace CONSUMER: it installs packages and enforces
# revocations, but it never signs anything, so it holds NO private key. The
# marketplace signing key lives only in the separate, private operator service
# (the Z-CMS Marketplace repo) that runs marketplace.z-cms.org.
#
# The PUBLIC key below is pinned here and in site-runtime and plugin-runtime.
# Every package and every revocation list is verified against it, so a
# compromised cms-api cannot make anything run code it did not sign — it would
# have to forge a signature it has no key for. This key also decides WHICH
# marketplace the instance trusts: pin marketplace.z-cms.org's key to use the
# public marketplace, or pin your own registry's key to use a private one. The
# trust boundary is the key, not the hostname.
# ---------------------------------------------------------------------------
MARKETPLACE_PUBLIC_KEY="<the marketplace's Ed25519 public key, SPKI PEM>"

# ---------------------------------------------------------------------------
# FIRST-PARTY SIGNING — the key the BUILT-IN plugins are verified against.
#
# The marketplace key above answers "did Z-CMS review this stranger's code?".
# This one answers a question nobody used to ask: "is the code we ship ourselves
# the code we signed?"
#
# It used to be assumed rather than checked. plugin-runtime read
# plugins/zai/dist/index.js off the volume and ran it, on the grounds that the
# volume belongs to the operator — which is true right up until it is a bad image
# layer, a mounted host path, or a compromised CI step. Built-in code holds the
# most privilege in the system (zAI has `network:fetch` and spends the site's API
# keys), and it was the only code with no signature between it and the isolate.
#
# Now every built-in ships as a signed .zcms and is verified against this key
# before a byte of it executes. The private half is NOT in this repo and must not
# be: it lives in a secret manager, and `pnpm sign:plugins` is what uses it.
#
# Rotating it means re-signing every built-in AND updating this value everywhere.
# A runtime pinned to the old key will refuse to run the new plugins, which is the
# system working rather than breaking.
# ---------------------------------------------------------------------------
FIRST_PARTY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMCowBQYDK2VwAyEAKlZg1nED9EybjxuY9Oah8ppD/3n09jOngODUVzeXFJw=\n-----END PUBLIC KEY-----"

# ---------------------------------------------------------------------------
# OPERATOR key — the THIRD trust anchor, for sideloading (installing a theme or
# plugin from a file, without the marketplace). All three below are OPTIONAL and
# blank by default; leave them and the sideload endpoints refuse every upload.
#
# OPERATOR_PUBLIC_KEY is pinned by site-runtime, plugin-runtime and cms-api, and a
# sideload is verified against it — the same discipline as FIRST_PARTY, one anchor
# over. Generate a fresh pair with `zcms keygen`; this is its public half. Not a
# secret. Prefer a distinct key per instance.
OPERATOR_PUBLIC_KEY=""
# OPERATOR_PRIVATE_KEY: set ONLY to enable the .zip convenience path, where cms-api
# packs and signs uploads for you. The trade-off: an attacker who owns cms-api can
# then sign code site-runtime runs. Leave it blank and sign offline instead —
# `zcms pack --operator-key private.pem` — so the private key never touches the
# server. NEVER place it on site-runtime or plugin-runtime.
OPERATOR_PRIVATE_KEY=""
# ALLOW_THEME_SIDELOAD: a theme runs UNSANDBOXED in site-runtime, so sideloading one
# is code execution in the page-rendering process. Off until set to "true" on
# purpose. Plugin sideload is not gated here (a plugin runs in the isolate).
ALLOW_THEME_SIDELOAD="false"

# Where this instance SHOPS: the marketplace it browses, installs from, and pulls
# the signed revocation list from.
#
#   MARKETPLACE_URL="https://marketplace.z-cms.org"
#
# Point it at a registry that serves /api/v1/registry/* (the public Z-SOFT
# marketplace, or a compatible private one). Publishing, review, and
# counter-signing are NOT part of this build — they live in the private operator
# service.
#
# Only the operator sets this. It is never taken from a request: if a tenant could
# name the host a package is fetched from, "install a theme" would become a
# request-forgery primitive aimed at whatever the API server can reach — which on
# most clouds includes the metadata service. Installs name a package, never a URL.
#
# Note that this is NOT the trust boundary. MARKETPLACE_PUBLIC_KEY is. Pointing
# this at a hostile host gets you packages that fail verification, not packages
# that run.
MARKETPLACE_URL=""

# ---------------------------------------------------------------------------
# Worker (BullMQ). First-party infrastructure — holds S3 + DB credentials, but
# NOT the marketplace or JWT signing keys.
# ---------------------------------------------------------------------------
WORKER_CONCURRENCY="4"

# ---------------------------------------------------------------------------
# Security alerting. Any endpoint that accepts a JSON POST. Four events are
# pushed here AND logged at error level: session theft detected, a revoked token
# still in use, a package quarantined by the scanner, a job dead-lettered.
# Empty = log only.
# ---------------------------------------------------------------------------
SECURITY_ALERT_WEBHOOK=""

# Behind a proxy this must name the real hop count (e.g. "1"), not "true" —
# otherwise a client can forge X-Forwarded-For and dodge the per-IP rate limit.
TRUST_PROXY="loopback"

# Serve the Swagger UI and the OpenAPI document at /api/v1/docs.
#
# On everywhere, production included: Z-CMS is meant to be integrated against,
# and docs that only exist on a laptop are docs nobody building against a real
# instance can read. The document discloses nothing a caller could not learn by
# trying — the guard, not the document, is what refuses a request.
#
# Self-hosting a single private site, with no third party writing a client
# against it? Then the docs buy you nothing, and "false" removes /api/v1/docs
# entirely — the API itself is untouched, only the page describing it goes.
SWAGGER_ENABLED="true"

# Where runtimes keep verified package bundles. Purged when a version is revoked.
THEME_CACHE_DIR=".zcms-themes"

# Where the SIGNED built-in themes live in local/dev runs. Production images carry
# their own copy under /app/themes; do not bind-mount a host themes directory over it
# unless that host directory contains the exact signed .zcms versions registered in
# the database. site-runtime verifies each package against FIRST_PARTY_PUBLIC_KEY
# before importing it, because a theme is not sandboxed.
THEME_DIR="./themes"
PLUGIN_CACHE_DIR=".zcms-plugins"
